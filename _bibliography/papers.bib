@inproceedings{tian2026multi,
  title={Multi-dimensional Neural Decoding with Orthogonal Representations for Brain-Computer Interfaces},
  author={Tian, Kaixi and Zhao, Shengjia and Zhang, Yuhan and Yu, Shan},
  booktitle={Proceedings of the AAAI Conference on Artificial Intelligence},
  volume={40},
  number={3},
  pages={2092--2100},
  year={2026},
  publisher={AAAI Press},
  doi={10.1609/aaai.v40i3.37191},
  selected={true},
  html={<b>Highlight:</b> To address cross-task interference in multi-dimensional brain-computer interfaces (BCIs), we propose OrthoSchema, a multi-task framework inspired by cortical orthogonal subspace organization. It enforces representation orthogonality to eliminate interference and employs selective feature reuse for robust cross-session and cross-subject transfer.<br><b>论文简介：</b>针对多维脑机接口（BCI）中跨任务信号相互干扰与泛化性差的挑战，本文提出了一种受大脑皮层正交子空间组织和认知图式复用启示的多任务解码框架 OrthoSchema。该框架通过施加表示正交性约束来消除任务间干扰，并利用选择性特征复用实现了跨场次、跨个体的鲁棒迁移。}
}

@article{tian2026domain,
  title={Domain-specific schema reuse supports flexible learning to learn in the primate brain},
  author={Tian, Kaixi and Zhao, Zhiping and Chen, Yang crumbled and Ge, Ningling and Cao, Shenghao and Han, Xinyong and Gu, Jianwen and Yu, Shan},
  journal={Nature Communications},
  year={2026},
  month={1},
  publisher={Nature Publishing Group},
  selected={true},
  html={<b>Highlight:</b> This work investigates the neural mechanisms of "learning to learn" in the primate brain. By analyzing high-dimensional neural data from the dorsolateral premotor cortex of macaques, we demonstrate how the brain resolves the stability-plasticity dilemma by representing stable cognitive schemas and task-unique changes in a near-orthogonal manner.<br><b>论文简介：</b>本文深入探究了灵长类大脑“学会学习”的神经机制。通过分析猕猴背侧前运动皮层的高维神经数据，我们发现大脑通过将稳定的认知图式（Schema）与任务特异性变化以近乎正交的方式进行表征，从而完美解决了记忆稳定性和行为灵活性之间的矛盾。}
}

@article{zhao2023low,
  title={Low-Dose Ketamine-Induced Deficits in Arbitrary Visuomotor Mapping in Monkeys},
  author={Zhao, Zhi-Ping and Nie, Chuang and Jiang, Cheng- Teng and Cao, Sheng-Hao and Tian, Kai-Xi and Han, Xin-Yong and Yu, Shan and Gu, Jian-Wen},
  journal={eNeuro},
  volume={10},
  number={6},
  year={2023},
  month={6},
  publisher={Society for Neuroscience},
  selected={false},
  html={<b>Highlight:</b> This study investigates the impact of acute low-dose ketamine administration on arbitrary visuomotor mapping (AVM) in macaques. The results show significant impairments in associative learning, characterized by lowered accuracy and prolonged planning time.<br><b>论文简介：</b>本研究探讨了急性低剂量氯胺酮注射对猕猴任意视觉运动映射（AVM）能力的影响。研究表明，低剂量氯胺酮会显著损害灵长类动物的联想学习能力，表现为准确率下降以及动作规划与执行时间的延长。}
}

@article{zhao2023modulating,
  title={Modulating brain activity with invasive brain--computer interface: a narrative review},
  author={Zhao, Zhi-Ping and Nie, Chuang and Jiang, Cheng-Teng and Cao, Sheng-Hao and Tian, Kai-Xi and Yu, Shan and Gu, Jian-Wen},
  journal={Brain Sciences},
  volume={13},
  number={1},
  pages={134},
  year={2023},
  month={1},
  publisher={MDPI},
  selected={false},
  html={<b>Highlight:</b> A comprehensive review tracking the historical progress and recent milestones of invasive BCIs, with a particular focus on technologies that modulate brain activity via cortical and deep brain electrical stimulation.<br><b>论文简介：</b>本文系统综述了侵入式脑机接口（BCI）的历史进程与最新进展，重点探讨了通过皮层和深部脑组织电刺激来调节大脑活动的双向闭环技术，并讨论了其临床应用中的伦理问题。}
}
